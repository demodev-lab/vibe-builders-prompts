## ✅ 올바른 사용 패턴

### Next.js App Router 패턴
```typescript
// ✅ Server Component (기본)
export default async function Page() {
  const data = await fetch('https://api.example.com')
  return <div>{data}</div>
}

// ✅ Client Component (필요시에만)
'use client'
export default function ClientPage() {
  const [state, setState] = useState(0)
  return <button onClick={() => setState(state + 1)}>{state}</button>
}

// ✅ 메타데이터 설정
export const metadata = {
  title: '페이지 제목',
  description: '페이지 설명'
}
```

### ShadCN 컴포넌트 확장
```typescript
// ✅ 기본 컴포넌트 가져오기
npx shadcn-ui@latest add button input form dialog

// ✅ Variant 확장
const buttonVariants = cva(
  "base-classes",
  {
    variants: {
      variant: {
        default: "기본 스타일",
        custom: "커스텀 스타일" // 새로운 variant 추가
      }
    }
  }
)

// ✅ 래핑 컴포넌트 생성 (ShadCN 파일 직접 수정 대신)
export function CustomButton({ children, ...props }) {
  return (
    <Button className="추가-스타일" {...props}>
      {children}
    </Button>
  )
}
```

