### Structure Code Logically
```ruby
# ✅ DO: Group related functionality
class UserRegistrationService
  def initialize(user_params)
    @user_params = user_params
  end

  def call
    return failure_result("Invalid parameters") unless valid_params?

    user = create_user
    return failure_result(user.errors.full_messages) unless user.persisted?

    send_welcome_email(user)
    success_result(user)
  end

  private

  # Validation methods
  def valid_params?
    # Implementation
  end

  # Core business logic
  def create_user
    # Implementation
  end

  # Side effects
  def send_welcome_email(user)
    # Implementation
  end

  # Result helpers
  def success_result(data)
    # Implementation
  end

  def failure_result(errors)
    # Implementation
  end
end
